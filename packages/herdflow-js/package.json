{
  "name": "@baby-yak/herdflow-js",
  "version": "0.1.3",
  "description": "Services library",
  "license": "MIT",
  "author": "its.yak@gmail.com",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/baby-yak/herdflow-js",
    "directory": "packages/herdflow-js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "local-test": "cd src/__local_tests && tsx --"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "expect-type": "^1.2.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "event",
    "events",
    "events-emitter",
    "eventemitter",
    "typed",
    "typescript",
    "async",
    "wildcard"
  ],
  "dependencies": {
    "immer": "^11.1.4"
  }
}
