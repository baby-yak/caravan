{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "outputLogs": "new-only"
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only"
    },
    "lint": {},
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
